# Root app environment for `app.py` and the main backend.
# The `wine_picture_detection` folder can also have its own local `.env` for standalone work.
#
# Copy this file to `.env` in the same directory before running `docker compose up`:
#   cp .env.example .env
# Then fill in CLUSTER_URL and API_KEY (see README "Get your SIE credentials" section).

# --- SIE cluster (required) ---
# You bring your own SIE cluster. These values come from the SIE dashboard for a
# managed cluster, or from your local SIE server config if self-hosting.
# See https://sie.dev/docs/quickstart for setup options.
CLUSTER_URL=https://your-sie-cluster-url
API_KEY=your-sie-api-key

# --- Reranker configuration ---
# "custom" uses SIE `encode` on tasting notes and reviews, then cosine-scores
# candidates against the user query. Works with the bundled SQLite catalog
# (which has no per-wine reviews).
# "standard" uses SIE `score` to rerank candidate reviews against prompt terms.
# Requires wines to have populated reviews - re-run db_creation to fetch them
# from Vivino, otherwise every wine will score 0 and matchPercentage will be 0%.
RERANK_METHOD=custom
SIE_RERANK_MODEL=BAAI/bge-reranker-v2-m3
SIE_EMBEDDING_MODEL=BAAI/bge-m3
RERANK_ALPHA=0.7
CUSTOM_RERANK_A=0.75
CUSTOM_RERANK_NO_REVIEW_PENALTY=0.5

# --- SIE runtime options ---
SIE_GPU=l4-spot
SIE_PROVISION_TIMEOUT_S=900

# --- OpenAI (optional) ---
# Only required for the /analyze-flavor-prompt endpoint, which turns a
# natural-language wine description into structure and flavor weights.
# Get a key at https://platform.openai.com/api-keys.
# Leave this unset if you don't need the natural-language prompt feature.
OPENAI_API_KEY=your-openai-api-key
