# Local environment for standalone `wine_picture_detection` scripts.
# The main app backend uses the root `.env` instead.

CLUSTER_URL=http://localhost:8080
# Optional: only needed for managed/auth-enabled SIE clusters.
API_KEY=
DATABASE_PATH=wine_flavor.db
TOP_N=5
SCORE_THRESHOLD=0
SIE_OCR_MODEL=microsoft/Florence-2-base
OCR_GPU=l4-spot
OCR_PROVISION_TIMEOUT_S=900
