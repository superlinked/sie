# Copy this file to `.env` and fill in the keys for the mode you want.
# Zero-setup mode works with none of these set: the local fallback
# ranker runs against the bundled demo catalog.

# ── Hugging Face ──────────────────────────────────────────────────────
# Optional. Raises API rate limits when downloading model metadata.
HF_TOKEN=

# ── OpenAI (optional) ─────────────────────────────────────────────────
# Used if you want OpenAI-backed description generation.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── OpenRouter (full mode) ────────────────────────────────────────────
# Used for LLM-generated descriptions in full mode.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.1-pro-preview
LLM_MAX_PARALLEL=20

# ── Superlinked Inference Engine ──────────────────────────────────────
# Leave these blank to run in zero-setup (local fallback) mode.
# For live embedding search, set SIE_API_ENDPOINT. SIE_API_KEY is optional
# and only needed for managed/auth-enabled SIE clusters.
SIE_API_KEY=
SIE_API_ENDPOINT=
SIE_GPU_PROFILE=l4-spot
SIE_EMBED_BATCH_SIZE=32
SIE_EMBED_MODEL=NovaSearch/stella_en_400M_v5

# ── Storage paths (defaults are fine) ─────────────────────────────────
# SQLITE_PATH=data/sqlite/sie.db
# CHROMA_PATH=data/chroma
# HF_CACHE_DIR=data/hf-cache
