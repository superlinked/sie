    {
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "id": 10,
      "title": "JetStream Memory Usage",
      "description": "NATS JetStream memory store usage. Alert if approaching the 512MB limit (configurable via nats.config.jetstream.memoryStore.maxSize).",
      "type": "timeseries",
