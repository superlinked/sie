  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Latency Breakdown by Phase",
      "type": "row"
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(sie_gateway_request_latency_seconds_bucket{namespace=\"$namespace\"}[$rate_window])) by (le)) * 1000",
          "legendFormat": "p50",
          "refId": "A"
        }
      ],
      "title": "Gateway E2E p50 (ms)",
      "type": "stat",
      "fieldConfig": {
        "defaults": { "unit": "ms", "thresholds": { "mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 100}, {"color": "red", "value": 500}] } }
      }
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(sie_gateway_request_latency_seconds_bucket{namespace=\"$namespace\"}[$rate_window])) by (le)) * 1000",
          "legendFormat": "p99",
          "refId": "A"
        }
      ],
      "title": "Gateway E2E p99 (ms)",
      "type": "stat",
      "fieldConfig": {
        "defaults": { "unit": "ms", "thresholds": { "mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 200}, {"color": "red", "value": 1000}] } }
      }
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sum(rate(sie_gateway_requests_total{namespace=\"$namespace\"}[$rate_window]))",
          "legendFormat": "Requests/s",
          "refId": "A"
        }
      ],
      "title": "Throughput (req/s)",
      "type": "stat",
      "fieldConfig": {
        "defaults": { "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [{"color": "green", "value": null}] } }
      }
    },
    {
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sum(rate(sie_gateway_requests_total{namespace=\"$namespace\", status!=\"200\"}[$rate_window])) / sum(rate(sie_gateway_requests_total{namespace=\"$namespace\"}[$rate_window])) * 100",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ],
      "title": "Error Rate",
      "type": "stat",
      "fieldConfig": {
        "defaults": { "unit": "percent", "noValue": "0%", "thresholds": { "mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}] } }
      }
    },
    {
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 5 },
      "id": 5,
      "title": "Latency Breakdown Over Time (mean, stacked)",
      "description": "Stacked mean latency by phase. Uses mean (not percentiles) because means are additive. Decomposition: E2E = gateway_overhead + result_wait. result_wait = publish_and_overhead + queue_transit + tokenization + inference. Stacked bars sum to total mean E2E.",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "custom": { "stacking": { "mode": "normal", "group": "A" }, "fillOpacity": 30, "lineWidth": 1 },
          "unit": "ms"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Gateway overhead" }, "properties": [{ "id": "color", "value": { "fixedColor": "#B877D9", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "NATS publish + overhead" }, "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Queue transit" }, "properties": [{ "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Tokenization" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2CC0C", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "GPU inference" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "clamp_min((\n  sum(rate(sie_gateway_request_latency_seconds_sum{namespace=\"$namespace\"}[$rate_window])) / sum(rate(sie_gateway_request_latency_seconds_count{namespace=\"$namespace\"}[$rate_window]))\n  - sum(rate(sie_gateway_queue_result_wait_seconds_sum{namespace=\"$namespace\"}[$rate_window])) / sum(rate(sie_gateway_queue_result_wait_seconds_count{namespace=\"$namespace\"}[$rate_window]))\n) * 1000, 0)",
          "legendFormat": "Gateway overhead",
          "refId": "A"
        },
        {
          "expr": "clamp_min((\n  sum(rate(sie_gateway_queue_result_wait_seconds_sum{namespace=\"$namespace\"}[$rate_window])) / sum(rate(sie_gateway_queue_result_wait_seconds_count{namespace=\"$namespace\"}[$rate_window]))\n  - sum(rate(sie_pull_loop_queue_wait_seconds_sum{namespace=\"$namespace\"}[$rate_window])) / sum(rate(sie_pull_loop_queue_wait_seconds_count{namespace=\"$namespace\"}[$rate_window]))\n  - sum(rate(sie_request_duration_seconds_sum{namespace=\"$namespace\", phase=\"tokenize\"}[$rate_window])) / sum(rate(sie_request_duration_seconds_count{namespace=\"$namespace\", phase=\"tokenize\"}[$rate_window]))\n  - sum(rate(sie_request_duration_seconds_sum{namespace=\"$namespace\", phase=\"inference\"}[$rate_window])) / sum(rate(sie_request_duration_seconds_count{namespace=\"$namespace\", phase=\"inference\"}[$rate_window]))\n) * 1000, 0)",
          "legendFormat": "NATS publish + overhead",
          "refId": "B"
        },
        {
          "expr": "sum(rate(sie_pull_loop_queue_wait_seconds_sum{namespace=\"$namespace\"}[$rate_window])) / sum(rate(sie_pull_loop_queue_wait_seconds_count{namespace=\"$namespace\"}[$rate_window])) * 1000",
          "legendFormat": "Queue transit",
          "refId": "C"
        },
        {
          "expr": "sum(rate(sie_request_duration_seconds_sum{namespace=\"$namespace\", phase=\"tokenize\"}[$rate_window])) / sum(rate(sie_request_duration_seconds_count{namespace=\"$namespace\", phase=\"tokenize\"}[$rate_window])) * 1000",
          "legendFormat": "Tokenization",
          "refId": "D"
        },
        {
          "expr": "sum(rate(sie_request_duration_seconds_sum{namespace=\"$namespace\", phase=\"inference\"}[$rate_window])) / sum(rate(sie_request_duration_seconds_count{namespace=\"$namespace\", phase=\"inference\"}[$rate_window])) * 1000",
          "legendFormat": "GPU inference",
          "refId": "E"
        }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 6,
      "title": "E2E Latency Percentiles Over Time (Gateway)",
      "description": "Gateway-measured end-to-end latency: sie_gateway_request_latency_seconds.",
      "type": "timeseries",
      "fieldConfig": {
