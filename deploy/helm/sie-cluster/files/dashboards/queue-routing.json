    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 7,
      "title": "Worker-Side Total Latency Percentiles",
      "description": "Worker-measured total request duration: sie_request_duration_seconds{phase=\"total\"}.",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(sie_request_duration_seconds_bucket{namespace=\"$namespace\", phase=\"total\"}[$rate_window])) by (le)) * 1000",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(sie_request_duration_seconds_bucket{namespace=\"$namespace\", phase=\"total\"}[$rate_window])) by (le)) * 1000",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(sie_request_duration_seconds_bucket{namespace=\"$namespace\", phase=\"total\"}[$rate_window])) by (le)) * 1000",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 101,
      "title": "NATS Queue Health (requires nats.promExporter.enabled=true)",
      "type": "row"
    },
    {
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "id": 8,
      "title": "Consumer Pending Messages",
      "description": "Messages waiting in the queue for workers to pull. Sustained growth means workers can't keep up.",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 15 } }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "nats_consumer_num_pending{namespace=\"$namespace\", stream_name=~\"WORK_POOL.*\"}",
          "legendFormat": "{{stream_name}} / {{consumer_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "id": 9,
      "title": "Consumer Ack Pending (In-Flight)",
      "description": "Messages pulled by workers but not yet acknowledged. Shows in-flight work.",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 15 } }
