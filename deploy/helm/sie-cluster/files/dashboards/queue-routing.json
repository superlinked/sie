        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(sie_gateway_queue_result_wait_seconds_bucket{namespace=\"$namespace\"}[$rate_window])) by (le, operation)) * 1000",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
