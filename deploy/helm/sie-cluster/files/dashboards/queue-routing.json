    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "id": 12,
      "title": "DLQ Events",
      "description": "Messages that exhausted max delivery attempts. Source: sie_gateway_dlq_events_total{stream, consumer}.",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 15 } }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
