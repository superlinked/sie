      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "changes(up{namespace=\"$namespace\", job=~\".*worker.*\"}[5m])",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "title": "Worker Status Changes",
      "type": "timeseries"
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 2,
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "max"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{namespace=\"$namespace\", container=\"worker\"} / 1024 / 1024 / 1024",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "title": "Memory Usage (GB)",
      "type": "timeseries"
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 3,
      "options": {
        "legend": {
